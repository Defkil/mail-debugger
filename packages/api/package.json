{
  "name": "mail-debugger-api",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Slim SMTP + REST API build of Mail Debugger. Same wire protocol as mail-debugger, without the web UI — meant for CI/E2E where a small footprint matters.",
  "type": "module",
  "homepage": "https://github.com/Defkil/mail-debugger#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Defkil/mail-debugger.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/Defkil/mail-debugger/issues"
  },
  "keywords": [
    "smtp",
    "email",
    "mail",
    "debugger",
    "fake-smtp",
    "catch-all",
    "testing",
    "e2e",
    "ci",
    "api"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mail-debugger-api": "./dist/main.mjs"
  },
  "scripts": {
    "prepack": "pnpm -w exec nx build mail-debugger-api --skip-nx-cache"
  },
  "nx": {
    "targets": {
      "sync-dist": {
        "dependsOn": [
          "@mail-debugger/server:build-api"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/dist"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "node -e \"const fs=require('fs'),path=require('path');const src='apps/server/dist-api',dst='packages/api/dist';fs.rmSync(dst,{recursive:true,force:true});fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){const s=path.join(src,f);if(fs.statSync(s).isFile())fs.copyFileSync(s,path.join(dst,f))}\""
        }
      },
      "build": {
        "dependsOn": [
          "sync-dist"
        ],
        "executor": "nx:noop"
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sql.js": "^1.14.1"
  }
}
