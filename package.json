{
  "name": "mail-debugger",
  "version": "0.2.3",
  "license": "MIT",
  "description": "Lightweight fake SMTP server that catches emails during development. Inspect, filter, and manage caught emails through a REST API, web UI, or terminal client.",
  "type": "module",
  "homepage": "https://github.com/Defkil/mail-debugger#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Defkil/mail-debugger.git"
  },
  "bugs": {
    "url": "https://github.com/Defkil/mail-debugger/issues"
  },
  "keywords": [
    "smtp",
    "email",
    "mail",
    "debugger",
    "fake-smtp",
    "maildev",
    "catch-all",
    "testing",
    "development"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mail-debugger": "./apps/server/dist/main.mjs"
  },
  "scripts": {
    "setup": "husky",
    "build": "nx build @mail-debugger/server",
    "prepack": "nx build @mail-debugger/server --skip-nx-cache"
  },
  "files": [
    "apps/server/dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/swagger": "^1.3.1",
    "@rezi-ui/core": "^0.1.0-alpha.0",
    "@rezi-ui/node": "^0.1.0-alpha.0",
    "elysia": "^1.4.28",
    "mailparser": "^3.9.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "selfsigned": "^5.5.0",
    "smtp-server": "^3.18.4",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/esbuild": "22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/node": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.21.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/svelte-query": "^5.75.7",
    "@tanstack/svelte-table": "9.0.0-alpha.32",
    "@types/mailparser": "^3.4.6",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^8.0.0",
    "@types/smtp-server": "^3.5.13",
    "@types/sql.js": "^1.4.11",
    "esbuild": "^0.27.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.4.0",
    "nodemailer": "^8.0.5",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.34.7",
    "svelte-check": "^4.2.1",
    "tailwindcss": "^4.1.8",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "nx",
      "unrs-resolver"
    ]
  }
}
