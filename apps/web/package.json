{
  "name": "@mail-debugger/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/build"
        ],
        "options": {
          "command": "npx svelte-kit sync && npx vite build",
          "cwd": "apps/web"
        }
      },
      "serve": {
        "continuous": true,
        "dependsOn": [
          "@mail-debugger/server:serve"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "npx vite dev --port 5173",
          "cwd": "apps/web"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx vitest run",
          "cwd": "apps/web"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx svelte-kit sync && npx svelte-check --tsconfig ./tsconfig.json",
          "cwd": "apps/web"
        }
      }
    }
  },
  "dependencies": {
    "@mail-debugger/api-client": "workspace:*",
    "@mail-debugger/types": "workspace:*"
  }
}
