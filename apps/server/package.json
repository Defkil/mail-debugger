{
  "name": "@mail-debugger/server",
  "version": "0.0.1",
  "bin": {
    "mail-debugger": "./dist/main.mjs"
  },
  "nx": {
    "targets": {
      "compile": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/server/dist",
          "format": [
            "esm"
          ],
          "bundle": true,
          "main": "apps/server/src/main.ts",
          "tsConfig": "apps/server/tsconfig.app.json",
          "assets": [
            "apps/server/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".mjs"
            },
            "banner": {
              "js": "#!/usr/bin/env node"
            },
            "conditions": [
              "mail-debugger"
            ],
            "external": [
              "better-sqlite3",
              "pino",
              "pino-pretty",
              "@rezi-ui/core",
              "@rezi-ui/node",
              "@rezi-ui/native"
            ]
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".mjs"
              },
              "banner": {
                "js": "#!/usr/bin/env node"
              },
              "conditions": [
                "mail-debugger"
              ],
              "external": [
                "better-sqlite3",
                "@rezi-ui/core",
                "@rezi-ui/node",
                "@rezi-ui/native"
              ]
            }
          }
        }
      },
      "compile-api": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/server/dist-api",
          "format": [
            "esm"
          ],
          "bundle": true,
          "main": "apps/server/src/main-api.ts",
          "outputFileName": "main.js",
          "tsConfig": "apps/server/tsconfig.app.json",
          "assets": [],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".mjs"
            },
            "banner": {
              "js": "#!/usr/bin/env node"
            },
            "conditions": [
              "mail-debugger"
            ],
            "external": [
              "better-sqlite3",
              "pino",
              "pino-pretty",
              "@rezi-ui/core",
              "@rezi-ui/node",
              "@rezi-ui/native"
            ]
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".mjs"
              },
              "banner": {
                "js": "#!/usr/bin/env node"
              },
              "conditions": [
                "mail-debugger"
              ],
              "external": [
                "better-sqlite3"
              ]
            }
          }
        }
      },
      "copy-web": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "@mail-debugger/web:build",
          "compile"
        ],
        "outputs": [
          "{workspaceRoot}/apps/server/dist/web"
        ],
        "options": {
          "command": "node -e \"const fs=require('fs');fs.cpSync('apps/web/build','apps/server/dist/web',{recursive:true})\""
        }
      },
      "build": {
        "dependsOn": [
          "compile",
          "copy-web"
        ],
        "executor": "nx:noop"
      },
      "build-api": {
        "dependsOn": [
          "compile-api"
        ],
        "executor": "nx:noop"
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/server/dist/package.json",
          "{workspaceRoot}/apps/server/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "compile"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/server/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "compile"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "compile"
        ],
        "options": {
          "buildTarget": "@mail-debugger/server:compile",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@mail-debugger/server:compile:development"
          },
          "production": {
            "buildTarget": "@mail-debugger/server:compile:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@mail-debugger/cli": "workspace:*",
    "@mail-debugger/types": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
