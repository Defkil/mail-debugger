{
  "name": "@mail-debugger/cli",
  "version": "0.0.1",
  "exports": {
    "./run-cli": {
      "mail-debugger": "./src/run-cli.ts",
      "types": "./dist/apps/cli/src/run-cli.d.ts",
      "import": "./dist/run-cli.mjs",
      "default": "./dist/run-cli.mjs"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/cli/dist",
          "format": [
            "esm"
          ],
          "bundle": true,
          "main": "apps/cli/src/main.ts",
          "tsConfig": "apps/cli/tsconfig.app.json",
          "assets": [],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".mjs"
            },
            "banner": {
              "js": "#!/usr/bin/env node"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".mjs"
              },
              "banner": {
                "js": "#!/usr/bin/env node"
              }
            }
          }
        }
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@mail-debugger/cli:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@mail-debugger/cli:build:development"
          },
          "production": {
            "buildTarget": "@mail-debugger/cli:build:production"
          }
        }
      },
      "test": {
        "command": "vitest run --passWithNoTests",
        "options": {
          "cwd": "apps/cli"
        }
      }
    }
  },
  "dependencies": {
    "@mail-debugger/api-client": "workspace:*",
    "@mail-debugger/types": "workspace:*",
    "@rezi-ui/core": "^0.1.0-alpha.0",
    "@rezi-ui/node": "^0.1.0-alpha.0"
  }
}
